{
  "manifest_version": 3,
  "name": "Vega Security Header Lens",
  "version": "0.1.0",
  "description": "Read-only HTTP security header analysis for authorized review. Observes response headers for user-granted origins and explains CSP, HSTS, framing, referrer, permissions, CORS, and cross-origin isolation signals.",
  "homepage_url": "https://github.com/Vega-Starboard/vega-security-header-lens",
  "icons": {
    "48": "icons/header-lens-48.svg",
    "96": "icons/header-lens-96.svg"
  },
  "permissions": [
    "activeTab",
    "storage",
    "webRequest"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ]
  },
  "action": {
    "default_title": "Analyze security headers",
    "default_popup": "src/popup.html",
    "default_icon": {
      "48": "icons/header-lens-48.svg",
      "96": "icons/header-lens-96.svg"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "security-header-lens@vega-starboard.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
